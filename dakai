#!/bin/zsh
set -euo pipefail

PROJECT_DIR="$(cd "$(dirname "$0")" && pwd)"
BACKEND_DIR="$PROJECT_DIR/backend"
FRONTEND_DIR="$PROJECT_DIR/frontend"
RUN_DIR="$PROJECT_DIR/.run"
DATASET_DIR="${NUSCENES_DATAROOT:-$HOME/Datasets/nuscenes-mini-5gb}"

BACKEND_PORT="${BACKEND_PORT:-8080}"
FRONTEND_PORT="${FRONTEND_PORT:-5173}"

mkdir -p "$RUN_DIR"

is_listening() {
  local port="$1"
  lsof -nP -iTCP:"$port" -sTCP:LISTEN >/dev/null 2>&1
}

wait_for_url() {
  local url="$1"
  local name="$2"
  local attempt

  for attempt in {1..30}; do
    if curl -fsS "$url" >/dev/null 2>&1; then
      echo "$name 已就绪：$url"
      return 0
    fi
    sleep 1
  done

  echo "$name 启动中，但暂时还没响应：$url"
  return 1
}

echo "启动 Autodrive 智驾 Demo..."

cd "$BACKEND_DIR"
if [[ ! -x ".venv/bin/python" ]]; then
  echo "创建后端 Python 虚拟环境..."
  python3 -m venv .venv
fi

if [[ ! -x ".venv/bin/uvicorn" ]] || \
  ! .venv/bin/python -c "import autodrive_harness" >/dev/null 2>&1; then
  echo "安装后端依赖..."
  (
    cd "$PROJECT_DIR"
    "$BACKEND_DIR/.venv/bin/python" -m pip install --upgrade pip
    "$BACKEND_DIR/.venv/bin/pip" install -r backend/requirements.txt
  )
fi

if [[ -d "$DATASET_DIR/v1.0-mini" ]]; then
  if [[ ! -f "$PROJECT_DIR/frontend/public/sample.mp4" ]] || \
    [[ ! -f "$PROJECT_DIR/frontend/public/perception.json" ]] || \
    ! grep -q '"frameMode": "continuous CAM_FRONT sample_data sweeps"' "$PROJECT_DIR/frontend/public/dataset-meta.json" 2>/dev/null || \
    ! grep -q '"sceneName": "scene-0796"' "$PROJECT_DIR/frontend/public/dataset-meta.json" 2>/dev/null || \
    ! grep -q '"cameraBox"' "$PROJECT_DIR/frontend/public/perception.json" 2>/dev/null; then
    echo "检测到 nuScenes mini，生成实景驾驶舱数据..."
    "$BACKEND_DIR/.venv/bin/python" "$PROJECT_DIR/scripts/convert_nuscenes_rich.py" \
      --dataroot "$DATASET_DIR" \
      --scene scene-0796 \
      --fps 12 \
      --render-fps 24 \
      --max-frames 360
    if "$BACKEND_DIR/.venv/bin/python" -c "import mcap" >/dev/null 2>&1; then
      "$BACKEND_DIR/.venv/bin/python" "$PROJECT_DIR/scripts/export_foxglove_mcap.py" || true
    fi
  fi
elif [[ ! -f "$PROJECT_DIR/frontend/public/sample.mp4" ]]; then
  echo "未找到 nuScenes mini，也没有本地 sample.mp4。"
  echo "前端仍会启动，但视频区域会缺少实景画面。"
  echo "要完整复现本地实景 Demo，请下载 nuScenes mini 后运行："
  echo "  NUSCENES_DATAROOT=/path/to/nuscenes-mini ./dakai"
fi

if is_listening "$BACKEND_PORT"; then
  echo "后端端口 $BACKEND_PORT 已在监听，跳过重复启动。"
else
  echo "启动后端：http://localhost:$BACKEND_PORT"
  : > "$RUN_DIR/backend.log"
  cat > "$RUN_DIR/start-backend.command" <<EOF
#!/bin/zsh
cd ${(qqq)BACKEND_DIR}
source .venv/bin/activate
uvicorn server:app --host 0.0.0.0 --port $BACKEND_PORT --reload 2>&1 | tee ${(qqq)RUN_DIR}/backend.log
EOF
  chmod +x "$RUN_DIR/start-backend.command"
  open -a Terminal "$RUN_DIR/start-backend.command"
fi

cd "$FRONTEND_DIR"
if [[ ! -d "node_modules" ]]; then
  echo "安装前端依赖..."
  npm install
fi

if is_listening "$FRONTEND_PORT"; then
  echo "前端端口 $FRONTEND_PORT 已在监听，跳过重复启动。"
else
  echo "启动前端：http://localhost:$FRONTEND_PORT"
  : > "$RUN_DIR/frontend.log"
  cat > "$RUN_DIR/start-frontend.command" <<EOF
#!/bin/zsh
cd ${(qqq)FRONTEND_DIR}
npm run dev -- --host 0.0.0.0 --port $FRONTEND_PORT 2>&1 | tee ${(qqq)RUN_DIR}/frontend.log
EOF
  chmod +x "$RUN_DIR/start-frontend.command"
  open -a Terminal "$RUN_DIR/start-frontend.command"
fi

wait_for_url "http://localhost:$BACKEND_PORT/health" "后端" || true
wait_for_url "http://localhost:$FRONTEND_PORT/" "前端" || true

echo
echo "前端页面：http://localhost:$FRONTEND_PORT/"
echo "后端健康检查：http://localhost:$BACKEND_PORT/health"
echo "日志目录：$RUN_DIR"
open "http://localhost:$FRONTEND_PORT/" >/dev/null 2>&1 || true
